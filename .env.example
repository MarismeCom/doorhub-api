# 数据库
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/doorhub

# JWT 鉴权
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ZK 设备（多设备逗号分隔）
ZK_DEVICE_IPS=192.168.1.201,192.168.1.202
ZK_DEVICE_PORT=4370
ZK_DEVICE_TIMEOUT=5
ZK_DEVICE_ENCODING=gbk
ZK_DEVICE_OMIT_PING=true

# 定时同步间隔（分钟）
SYNC_INTERVAL_MINUTES=5

# API 限流
RATE_LIMIT_PER_MINUTE=100

# 应用
APP_HOST=0.0.0.0
APP_PORT=8000
APP_TIMEZONE=Asia/Shanghai

# 考勤
ATTENDANCE_PLAN_START=09:00
ATTENDANCE_PLAN_END=18:00
ATTENDANCE_WORKDAY_PROVIDER=ailcc
ATTENDANCE_AILCC_API_BASE_URL=https://holiday.ailcc.com
ATTENDANCE_AILCC_API_TOKEN=

# 飞书企业应用
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=
FEISHU_ENABLE_LONG_CONNECTION=false
FEISHU_EVENT_SUBSCRIPTIONS=approval.approval.updated_v4,application.bot.menu_v6,im.message.message_read_v1
FEISHU_LOG_LEVEL=INFO
FEISHU_BOT_MENU_DOOR_OPEN_EVENT_KEY=door_open
FEISHU_BOT_MENU_DOOR_OPEN_DEVICE_IP=
FEISHU_BOT_MENU_DOOR_OPEN_SECONDS=3
FEISHU_BOT_MENU_NOTIFY_OPERATOR=false
FEISHU_BOT_MENU_DEVICE_EVENT_MAP=
FEISHU_BOT_MENU_ALLOWED_OPEN_IDS=
FEISHU_BOT_MENU_ALLOWED_USER_IDS=
